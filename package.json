{
    "name": "@doist/twist-ai",
    "version": "5.0.0",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "mcpName": "net.twist/mcp",
    "bin": {
        "twist-ai": "dist/main.js"
    },
    "files": [
        "dist",
        "package.json",
        "LICENSE",
        "README.md"
    ],
    "license": "MIT",
    "description": "A collection of tools for Twist using AI",
    "author": "Doist",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Doist/twist-ai.git"
    },
    "keywords": [
        "twist",
        "ai",
        "mcp",
        "doist",
        "collaboration",
        "model-context-protocol"
    ],
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "scripts": {
        "test": "jest",
        "build": "rimraf dist && npx tsc --project tsconfig.json",
        "postbuild": "chmod +x dist/main.js",
        "start": "npm run build && npx @modelcontextprotocol/inspector node dist/main.js",
        "dev": "concurrently \"npx tsc --watch\" \"npx @modelcontextprotocol/inspector npx nodemon --quiet --watch dist --ext js --exec node dist/main.js\"",
        "type-check": "npx tsc --noEmit",
        "format:check": "oxlint src scripts *.config.js && oxfmt --check",
        "format:fix": "oxlint src scripts *.config.js --fix && oxfmt",
        "prepublishOnly": "npm run build && npm test"
    },
    "dependencies": {
        "@doist/twist-sdk": "2.4.1",
        "dotenv": "17.4.2",
        "zod": "4.1.13"
    },
    "peerDependencies": {
        "@modelcontextprotocol/sdk": "^1.25.0"
    },
    "overrides": {
        "ts-jest": {
            "typescript": "$typescript"
        }
    },
    "devDependencies": {
        "@semantic-release/changelog": "6.0.3",
        "@semantic-release/git": "10.0.1",
        "@types/jest": "30.0.0",
        "@types/node": "22.19.17",
        "concurrently": "9.2.1",
        "conventional-changelog-conventionalcommits": "9.3.1",
        "jest": "30.3.0",
        "nodemon": "3.1.14",
        "oxfmt": "0.46.0",
        "oxlint": "1.61.0",
        "rimraf": "6.1.3",
        "semantic-release": "25.0.3",
        "ts-jest": "29.4.9",
        "typescript": "6.0.3"
    }
}
